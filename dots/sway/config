set $mod Mod4
set $term foot
set $browser firefox
set $menu rofi

font pango:MartianMono Nerd Font Bold 15

seat seat0 xcursor_theme Banana 40
exec_always export XCURSOR_SIZE=40
exec_always export XCURSOR_THEME=Banana

output eDP-1 mode 1920x1080@144Hz scale 1.0 transform 0

gaps inner 3
gaps outer 3
default_border pixel 3

focus_follows_mouse yes

set $base #303446
set $pink #f4b8e4
set $rosewater #f2d5cf
set $text #c6d0f5
set $overlay0 #737994

client.focused          $base      $pink      $base      $rosewater  $pink
client.focused_inactive $overlay0  $base      $text      $rosewater  $overlay0
client.unfocused        $overlay0  $base      $text      $rosewater  $overlay0
client.urgent           #e78284    $base      #e78284    $base       #e78284
client.background       $base

floating_modifier $mod

exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec autotiling
exec_always sh -c 'pkill waybar; sleep 0.2; waybar'
exec ~/.config/sway/battery-warning.sh
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store

exec sh -c 'pkill swayidle; swayidle -w \
 timeout 300 "swaylock -f" \
 timeout 600 "swaymsg \"output * dpms off\"" \
 resume "swaymsg \"output * dpms on\"" \
 before-sleep "swaylock -f"'

input * {
    xkb_layout us
    xkb_numlock enabled
    pointer_accel 0
}

input type:keyboard {
    repeat_delay 300
    repeat_rate 50
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
}

bindsym $mod+Return exec $term
bindsym $mod+space exec $menu -show drun
bindsym $mod+Ctrl+space exec cliphist list | $menu -dmenu -display-columns 2 | cliphist decode | wl-copy
bindsym $mod+Mod1+space exec rofimoji --selector "$menu" --action copy
bindsym $mod+b exec $browser
bindsym $mod+Shift+Escape exec swaylock -f

bindsym Print exec sh -c 'grim -t ppm -g "$(slurp)" - | satty --filename - --fullscreen --copy-command wl-copy --output-filename ~/Pictures/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png'
bindsym Shift+Print exec sh -c 'if pgrep -x wl-screenrec > /dev/null; then pkill -SIGINT wl-screenrec && notify-send -u normal -t 4000 "🎬 Recording Saved" "✅ Video written to ~/Videos — ready to use!"; else FILE=~/Videos/$(date +%Y-%m-%d_%H-%M-%S).mp4; REGION=$(slurp) && wl-screenrec --geometry "$REGION" -f "$FILE" & notify-send -u critical -t 3000 "🔴 Recording in Progress" "🎯 Region locked — press Shift+Print again to stop"; fi'

bindsym XF86AudioRaiseVolume exec sh -c 'wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+ && notify-send -h string:x-canonical-private-synchronous:volume "󰕾 Volume" "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk "{print int(\$2*100)}")%"'
bindsym XF86AudioLowerVolume exec sh -c 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && notify-send -h string:x-canonical-private-synchronous:volume "󰕾 Volume" "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk "{print int(\$2*100)}")%"'
bindsym XF86AudioMute exec sh -c 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && if wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED; then notify-send -h string:x-canonical-private-synchronous:volume "󰝟 Audio" "Muted"; else notify-send -h string:x-canonical-private-synchronous:volume "󰕾 Audio" "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk "{print int(\$2*100)}")%"; fi'
bindsym XF86AudioMicMute exec sh -c 'wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle && notify-send -h string:x-canonical-private-synchronous:mic "󰍬 Mic" "Toggled"'
bindsym XF86MonBrightnessUp exec sh -c 'brightnessctl set +5% && notify-send -h string:x-canonical-private-synchronous:brightness "󰃠 Brightness" "$(brightnessctl -m | cut -d, -f4)"'
bindsym XF86MonBrightnessDown exec sh -c 'brightnessctl set 5%- && if [ $(brightnessctl get) -lt $(($(brightnessctl max) / 100)) ]; then brightnessctl set 1%; fi && notify-send -h string:x-canonical-private-synchronous:brightness "󰃠 Brightness" "$(brightnessctl -m | cut -d, -f4)"'

bindsym $mod+q kill
bindsym $mod+Shift+f fullscreen toggle
bindsym $mod+Shift+space floating toggle

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+s layout stacking
bindsym $mod+Shift+t layout tabbed
bindsym $mod+Shift+e layout toggle split

bindsym $mod+s scratchpad show
bindsym $mod+Ctrl+s move scratchpad

bindsym Mod1+Shift+h resize shrink width 20 px
bindsym Mod1+Shift+j resize grow height 20 px
bindsym Mod1+Shift+k resize shrink height 20 px
bindsym Mod1+Shift+l resize grow width 20 px

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+r reload
bindsym $mod+Shift+q exec swaynag -t warning -m "exit sway?" -b "yes" "swaymsg exit"
